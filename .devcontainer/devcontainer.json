{
  "name": "HAU Codespace (web)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "if [ -f package.json ]; then npm install; fi",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": { "label": "Dev server", "onAutoForward": "openPreview" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "ms-vscode.live-server"]
    }
  }
}
